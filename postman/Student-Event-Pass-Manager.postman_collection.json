              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation { createEvent(input: { title: \\\"GraphQL Demo Event\\\", location: \\\"Illinois Tech\\\", eventDate: \\\"2026-06-15\\\", capacity: 40 }) { id title capacity availableSeats status } }\"\n}"
